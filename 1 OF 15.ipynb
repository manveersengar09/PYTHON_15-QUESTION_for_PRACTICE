   "source": [
    "1. Take a number from the user and check whether it is even or odd. "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "d91099ab-7054-4130-a59d-6b78f11da26e",
   "metadata": {},
   "outputs": [],
   "source": [
    "num = int(input(\"enter the number :- \"))\n",
    "if num % 2 == 0:\n",
    "    print(\"number is even\")\n",
    "    \n",
    "else:\n",
    "    print(\"number is odd\")"
   ]
  },
